# Copia a .env.local y rellena SMTP_PASS (nunca subas .env.local al repositorio).
#
# Gmail (culturaregenerativaac@gmail.com):
# 1. Verificación en 2 pasos activa.
# 2. Contraseña de aplicaciones → generar → pegar en SMTP_PASS (16 caracteres, sin espacios).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

SMTP_USER=culturaregenerativaac@gmail.com
SMTP_PASS=

SMTP_FROM=Cultura Regenerativa A.C. <culturaregenerativaac@gmail.com>

# Opcional: mismo buzón por defecto en código si lo omites.
# CONTACT_TO=culturaregenerativaac@gmail.com

# --- Stripe (donaciones con tarjeta) ---
# Dashboard: https://dashboard.stripe.com/apikeys
# - Desarrollo: usa clave sk_test_...
# - Producción: sk_live_... (activa el modo live en Stripe primero)
#
STRIPE_SECRET_KEY=

# Opcional pero recomendado con dominio propio (canonical, OpenGraph, retorno Stripe):
# NEXT_PUBLIC_SITE_URL=https://www.tu-dominio.org
#
# En Vercel suele bastar STRIPE_SECRET_KEY; si no defines NEXT_PUBLIC_SITE_URL,
# el sitio usa automáticamente https://TU-PROYECTO.vercel.app para redirecciones.
