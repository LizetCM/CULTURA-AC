# Copia a .env.local y rellena SMTP_PASS (nunca subas .env.local al repositorio).
#
# Gmail (cuenta de prueba lizetmc08@gmail.com):
# 1. Activa verificación en 2 pasos en la cuenta de Google.
# 2. Crea una "Contraseña de aplicaciones": Google cuenta → Seguridad →
#    Verificación en 2 pasos → Contraseñas de aplicaciones → Generar.
# 3. Pega esa contraseña de 16 caracteres en SMTP_PASS (sin espacios).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

SMTP_USER=lizetmc08@gmail.com
SMTP_PASS=

SMTP_FROM=Cultura AC <lizetmc08@gmail.com>

# Opcional: buzón donde caen contacto y bolsa de trabajo. Si lo omites, el código
# usa lizetmc08@gmail.com por defecto.
# CONTACT_TO=lizetmc08@gmail.com
