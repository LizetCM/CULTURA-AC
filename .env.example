# Copia a .env.local y rellena SMTP_PASS (nunca subas .env.local al repositorio).
#
# En Vercel: Project → Settings → Environment Variables
# Añade las MISMAS variables para "Production" (y Preview si pruebas ahí).
# Sin SMTP_HOST + SMTP_USER + SMTP_PASS los formularios NO envían correo (solo mensaje delivered:false).
#
# Gmail (culturaregenerativaac@gmail.com):
# 1. Verificación en 2 pasos activa.
# 2. Contraseña de aplicaciones → generar → pegar en SMTP_PASS (16 caracteres, sin espacios).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

SMTP_USER=culturaregenerativaac@gmail.com
SMTP_PASS=

SMTP_FROM=Cultiva A.C. <culturaregenerativaac@gmail.com>

# Correo visible en la web (mailto, pie, donaciones). Debe ser el mismo buzón
# que CONTACT_TO / SMTP_USER para que formularios y propuestas lleguen bien.
NEXT_PUBLIC_CONTACT_EMAIL=culturaregenerativaac@gmail.com

# Opcional: si difiere del correo público; si no, usa NEXT_PUBLIC_CONTACT_EMAIL.
# CONTACT_TO=culturaregenerativaac@gmail.com

# URL canónica del sitio (OpenGraph, enlaces absolutos). Opcional en Vercel:
# NEXT_PUBLIC_SITE_URL=https://www.tu-dominio.org
